# http://owen.cymru/sf-a-quick-way-to-search-for-some-thing-in-bash-and-edit-it-with-vim-2/
function ssf() {
    if [ $# -lt 1 ] ;
        then echo -e "Usage: Supply string to search for";
             echo -e "Example: ssf write"
        return 0;
    fi

  printf -v search "%q" "$*"
  include="yml,js,json,php,md,txt,styl,pug,jade,html,config,py,cpp,c,go,hs,rb,conf,fa,lst,f,f90"
  exclude=".config,.git,node_modules,vendor,build,yarn.lock,*.sty,*.bst,*.coffee,dist"
  rg_command='rg --column --line-number --no-heading --fixed-strings --ignore-case --no-ignore --hidden --follow --color "always" -g "*.{'$include'}" -g "!{'$exclude'}/*"'
  files=`eval $rg_command $search | fzf --ansi --multi --reverse | awk -F ':' '{print $1":"$2":"$3}'`
  [[ -n "$files" ]] && ${EDITOR:-vim} "$files"
}

